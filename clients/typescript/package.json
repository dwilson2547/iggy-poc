{
  "name": "iggy-typescript-client",
  "version": "1.0.0",
  "description": "TypeScript producer and consumer for Apache Iggy POC",
  "type": "module",
  "scripts": {
    "producer": "tsx src/producer.ts",
    "consumer": "tsx src/consumer.ts",
    "avro:producer": "tsx src/avroProducer.ts",
    "avro:consumer": "tsx src/avroConsumer.ts",
    "protobuf:producer": "tsx src/protobufProducer.ts",
    "protobuf:consumer": "tsx src/protobufConsumer.ts",
    "test": "vitest run"
  },
  "keywords": [
    "iggy",
    "messaging",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@iggy.rs/sdk": "^1.0.6",
    "avsc": "^5.7.9",
    "protobufjs": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
